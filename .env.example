# ROI-GEN environment contract
# cp .env.example .env — then see MANUAL-SETUP.md for where each key comes from.
# .env is gitignored. Backend reads via pydantic-settings (backend/app/core/config.py).
# NOTE: no inline comments on value lines (naive `source .env` poisons values).

# ── Application ─────────────────────────────────────────────
DEBUG=true
# Generate: openssl rand -hex 32
SECRET_KEY=
ALLOWED_EMAIL=seantokuzo@gmail.com

# ── Database / cache (docker-compose service defaults) ──────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roigen
REDIS_URL=redis://localhost:6379/0

# ── Auth (Google OAuth → JWT) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Alpaca (PAPER keys here; live keys are encrypted DB records, Phase 9) ──
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# iex (free) | sip (Algo Trader Plus, $99/mo — required before live)
ALPACA_DATA_FEED=iex

# ── LLM providers (Anthropic primary; others free-tier fallback) ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
LLM_PROVIDER_FAST=anthropic
LLM_PROVIDER_SMART=anthropic
LLM_PROVIDER_PREMIUM=anthropic

# ── Data sources ─────────────────────────────────────────────
FINNHUB_API_KEY=
FRED_API_KEY=

# ── Global risk defaults (per-strategy/portfolio overrides live in DB) ──
RISK_PER_TRADE_PCT=0.75
UNPROVEN_RISK_PER_TRADE_PCT=0.25
MAX_RISK_PER_TRADE_PCT=2.0
DAILY_LOSS_LIMIT_PCT=2.0
DAILY_LOSS_RISK_MULTIPLE=2.5
MAX_CONSECUTIVE_LOSSES=4
DRAWDOWN_HALVE_PCT=10.0
DRAWDOWN_HALT_PCT=15.0
MARGIN_HEADROOM_FACTOR=0.85
FLATTEN_BUFFER_MINUTES=5
SYMBOL_COOLDOWN_SECONDS=60

# ── CORS / frontend ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:4300,http://localhost:5173
